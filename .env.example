# Synaptica Gabi AI - Global API Keys Configuration
# Copia este archivo como '.env' e ingresa tus llaves para habilitar consultas reales globales.

# OpenAI Key (GPT-4o-mini / GPT-4)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Perplexity Key
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# DeepSeek Key
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Puerto del Servidor Backend (Opcional, por defecto 3001)
PORT=3001
