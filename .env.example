# Synaptica Gabi AI - Global Environment Configurations
# Copia este archivo como '.env' e ingresa tus valores.

# Configuración del Servidor y Seguridad
PORT=3001
JWT_SECRET=reemplazar_con_un_secreto_seguro_para_jwt
DATABASE_URL=postgresql://user:password@host:port/dbname

# --- MODELOS API (PRIORIDAD SECUNDARIA) ---
OPENAI_API_KEY=your_openai_key
ANTHROPIC_API_KEY=your_anthropic_key
GEMINI_API_KEY=your_gemini_key
GROK_API_KEY=your_grok_key
PERPLEXITY_API_KEY=your_perplexity_key
MISTRAL_API_KEY=your_mistral_api_key
QWEN_API_KEY=your_qwen_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# --- MODELOS LOCALES Y FALLBACKS (PRIORIDAD ALTA) ---
# Si se deja vacío el PROVIDER de un modelo, Gabi intentará buscarlo en Ollama (http://localhost:11434).
# Si se provee, Gabi consultará a ese endpoint compatible con OpenAI (LM Studio, vLLM, TGI, etc.)

LLAMA_PROVIDER=
LLAMA_MODEL=llama3.3

MISTRAL_PROVIDER=
MISTRAL_MODEL=mistral

QWEN_PROVIDER=
QWEN_MODEL=qwen2.5

DEEPSEEK_PROVIDER=
DEEPSEEK_MODEL=deepseek-coder

GEMMA_PROVIDER=
GEMMA_MODEL=gemma2

PHI_PROVIDER=
PHI_MODEL=phi3
